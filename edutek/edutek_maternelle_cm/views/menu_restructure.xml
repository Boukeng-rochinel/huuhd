<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════
         Pedagogie > Maternelle : regroupe le suivi des
         acquis/carnets de la Maternelle a part du suivi
         Notes & Bulletins (Primaire/Secondaire), defini
         dans edutek_primaire_cm - qui ne peut pas referencer
         ces elements-ci en retour (edutek_maternelle_cm en
         depend, pas l'inverse).
    ══════════════════════════════════════════ -->
    <menuitem id="menu_op_pedagogie_maternelle"
              name="Maternelle"
              parent="edutek_primaire_cm.menu_op_pedagogie"
              sequence="20"/>

    <record id="menu_op_student_skill_generate" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_pedagogie_maternelle"/>
        <field name="sequence">10</field>
    </record>
    <record id="menu_op_student_skill" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_pedagogie_maternelle"/>
        <field name="sequence">20</field>
    </record>
    <record id="menu_op_carnet_generate" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_pedagogie_maternelle"/>
        <field name="sequence">30</field>
    </record>
    <record id="menu_op_carnet" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_pedagogie_maternelle"/>
        <field name="sequence">40</field>
    </record>

</odoo>
