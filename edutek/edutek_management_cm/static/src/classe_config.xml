<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="edutek_management_cm.ClasseConfig">
    <div class="cc-root">
        <div t-if="state.loading" class="cc-loading">
            <i class="fa fa-spinner fa-spin fa-2x"/>
        </div>
        <div t-else="" class="cc-shell">

            <div class="cc-tabs">
                <div class="cc-tab" t-att-class="state.activeTab === 'structures' ? 'cc-tab--active' : ''"
                     t-on-click="() => this.switchTab('structures')">Structures</div>
                <div class="cc-tab" t-att-class="state.activeTab === 'info' ? 'cc-tab--active' : ''"
                     t-on-click="() => this.switchTab('info')">Informations</div>
                <div class="cc-tab" t-att-class="state.activeTab === 'matricule' ? 'cc-tab--active' : ''"
                     t-on-click="() => this.switchTab('matricule')">Matricule</div>
                <div class="cc-tab" t-att-class="state.activeTab === 'journaux' ? 'cc-tab--active' : ''"
                     t-on-click="() => this.switchTab('journaux')">Journaux</div>
                <div class="cc-tab" t-att-class="state.activeTab === 'personnel' ? 'cc-tab--active' : ''"
                     t-on-click="() => this.switchTab('personnel')">Personnel</div>
                <div class="cc-tab" t-att-class="state.activeTab === 'documents' ? 'cc-tab--active' : ''"
                     t-on-click="() => this.switchTab('documents')">Modeles de documents</div>
                <div class="cc-tab" t-att-class="state.activeTab === 'niveaux' ? 'cc-tab--active' : ''"
                     t-on-click="() => this.switchTab('niveaux')">Niveaux &amp; Cycles</div>
            </div>

        <div t-if="state.activeTab === 'structures'" class="cc-layout">

            <div class="cc-list-pane">
                <div class="cc-list-header">
                    <span>Classes</span>
                    <button class="cc-btn-new" t-on-click="startCreate">
                        <i class="fa fa-plus"/> Nouveau
                    </button>
                </div>
                <div class="cc-list">
                    <div t-if="!visibleClasses.length" class="cc-empty">Aucune classe.</div>
                    <t t-foreach="visibleClasses" t-as="classe" t-key="classe.id">
                        <div class="cc-list-row"
                             t-att-class="classe.id === state.selectedId ? 'cc-list-row--active' : ''"
                             t-on-click="() => this.selectClasse(classe.id)">
                            <div class="cc-list-row-name" t-esc="classe.name"/>
                            <div class="cc-list-row-meta">
                                <span t-esc="selectionLabel('level', classe.level)"/>
                                <span t-if="classeFeesTotal(classe.id)" t-esc="formatAmount(classeFeesTotal(classe.id))"/>
                            </div>
                        </div>
                    </t>
                </div>
            </div>

            <div class="cc-detail-pane">
                <div t-if="!selected and !state.isNew" class="cc-empty cc-empty--detail">
                    Selectionnez une classe a gauche, ou creez-en une nouvelle.
                </div>
                <t t-else="">
                    <div class="cc-detail-header">
                        <div class="cc-detail-title">Informations sur la classe</div>
                        <div class="cc-detail-actions">
                            <t t-if="!state.editMode">
                                <button class="btn btn-sm btn-primary" t-on-click="startEdit">
                                    <i class="fa fa-pencil"/> Modifier
                                </button>
                                <button class="cc-btn-danger" t-on-click="deleteSelected">
                                    <i class="fa fa-trash"/> Supprimer
                                </button>
                            </t>
                            <t t-else="">
                                <button class="btn btn-sm btn-primary" t-on-click="save" t-att-disabled="state.saving">
                                    <i class="fa fa-check"/> Enregistrer
                                </button>
                                <button class="btn btn-sm" t-on-click="cancelEdit">
                                    Annuler
                                </button>
                            </t>
                        </div>
                    </div>

                    <div t-if="state.editMode" class="cc-form">
                        <div class="cc-form-row">
                            <label>Nom</label>
                            <input type="text" t-model="state.draft.name"/>
                        </div>
                        <div class="cc-form-row">
                            <label>Niveau</label>
                            <select t-model="state.draft.level">
                                <option value="">-</option>
                                <t t-foreach="state.selections.level" t-as="opt" t-key="opt[0]">
                                    <option t-att-value="opt[0]" t-esc="opt[1]"/>
                                </t>
                            </select>
                        </div>
                        <div class="cc-form-row">
                            <label>Serie</label>
                            <select t-model="state.draft.serie">
                                <option value="">-</option>
                                <t t-foreach="state.selections.serie" t-as="opt" t-key="opt[0]">
                                    <option t-att-value="opt[0]" t-esc="opt[1]"/>
                                </t>
                            </select>
                        </div>
                        <div class="cc-form-row">
                            <label>2eme langue</label>
                            <select t-model="state.draft.deuxieme_langue">
                                <option value="">-</option>
                                <t t-foreach="state.selections.deuxieme_langue" t-as="opt" t-key="opt[0]">
                                    <option t-att-value="opt[0]" t-esc="opt[1]"/>
                                </t>
                            </select>
                        </div>
                        <div class="cc-form-row">
                            <label>Intitule abrege</label>
                            <input type="text" t-model="state.draft.intitule_abrege"/>
                        </div>
                        <div class="cc-form-row">
                            <label>Prefixe matricule</label>
                            <input type="text" t-model="state.draft.matricule_prefix" placeholder="Ex: CE2"/>
                        </div>
                        <div class="cc-form-row">
                            <label>Enseignant titulaire</label>
                            <select t-on-change="onTeacherChange">
                                <option value="">- Aucun -</option>
                                <t t-foreach="state.employees" t-as="emp" t-key="emp.id">
                                    <option t-att-value="emp.id"
                                            t-att-selected="state.draft.teacher_id === emp.id">
                                        <t t-esc="emp.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="cc-form-row">
                            <label>Moy. min de passage (par periode) /20</label>
                            <input type="number" step="0.01" t-model.number="state.draft.moy_min_passage_trimestre"/>
                        </div>
                        <div class="cc-form-row">
                            <label>Moy. min de passage (annee) /20</label>
                            <input type="number" step="0.01" t-model.number="state.draft.moy_min_passage_annee"/>
                        </div>
                        <div class="cc-form-row">
                            <label>Determinant de reussite</label>
                            <select t-model="state.draft.determinant_reussite">
                                <t t-foreach="state.selections.determinant_reussite" t-as="opt" t-key="opt[0]">
                                    <option t-att-value="opt[0]" t-esc="opt[1]"/>
                                </t>
                            </select>
                        </div>
                        <div class="cc-form-row">
                            <label>Type de bulletin</label>
                            <select t-model="state.draft.type_bulletin">
                                <t t-foreach="state.selections.type_bulletin" t-as="opt" t-key="opt[0]">
                                    <option t-att-value="opt[0]" t-esc="opt[1]"/>
                                </t>
                            </select>
                        </div>
                        <div class="cc-form-row cc-form-row--check">
                            <label>
                                <input type="checkbox" t-model="state.draft.bulletin_double"/>
                                Classe avec deux bulletins
                            </label>
                        </div>
                        <div class="cc-form-row cc-form-row--check">
                            <label>
                                <input type="checkbox" t-model="state.draft.bulletin_multi_pages"/>
                                Bulletin sur plusieurs pages
                            </label>
                        </div>
                    </div>

                    <div t-else="" class="cc-view">
                        <div class="cc-view-name" t-esc="selected.name"/>
                        <div class="cc-view-grid">
                            <div>
                                <span>Niveau</span>
                                <strong t-esc="selectionLabel('level', selected.level)"/>
                            </div>
                            <div>
                                <span>Serie</span>
                                <strong t-esc="selectionLabel('serie', selected.serie)"/>
                            </div>
                            <div>
                                <span>2eme langue</span>
                                <strong t-esc="selectionLabel('deuxieme_langue', selected.deuxieme_langue)"/>
                            </div>
                            <div>
                                <span>Intitule abrege</span>
                                <strong t-esc="selected.intitule_abrege || '-'"/>
                            </div>
                            <div>
                                <span>Prefixe matricule</span>
                                <strong t-esc="selected.matricule_prefix || '-'"/>
                            </div>
                            <div>
                                <span>Enseignant titulaire</span>
                                <strong t-esc="teacherName(selected.teacher_id)"/>
                            </div>
                            <div>
                                <span>Effectif</span>
                                <strong t-esc="selected.student_count"/>
                            </div>
                            <div>
                                <span>Moy. min (periode) /20</span>
                                <strong t-esc="selected.moy_min_passage_trimestre"/>
                            </div>
                            <div>
                                <span>Moy. min (annee) /20</span>
                                <strong t-esc="selected.moy_min_passage_annee"/>
                            </div>
                            <div>
                                <span>Determinant de reussite</span>
                                <strong t-esc="selectionLabel('determinant_reussite', selected.determinant_reussite)"/>
                            </div>
                            <div>
                                <span>Type de bulletin</span>
                                <strong t-esc="selectionLabel('type_bulletin', selected.type_bulletin)"/>
                            </div>
                            <div>
                                <span>Deux bulletins</span>
                                <strong t-esc="selected.bulletin_double ? 'Oui' : 'Non'"/>
                            </div>
                            <div>
                                <span>Plusieurs pages</span>
                                <strong t-esc="selected.bulletin_multi_pages ? 'Oui' : 'Non'"/>
                            </div>
                        </div>
                    </div>

                    <div t-if="selected" class="cc-fees">
                        <div class="cc-detail-title">Frais configures pour cette classe</div>
                        <table class="cc-fees-table">
                            <thead>
                                <tr><th>Type de frais</th><th>Montant</th><th/></tr>
                            </thead>
                            <tbody>
                                <t t-foreach="feeLinesForSelected" t-as="line" t-key="line.id">
                                    <tr>
                                        <td t-esc="line.fee_type_id[1]"/>
                                        <td>
                                            <input type="number" t-att-value="line.amount"
                                                   t-on-change="(ev) => this.updateFeeLineAmount(line, ev.target.value)"/>
                                        </td>
                                        <td>
                                            <button class="cc-btn-danger" t-on-click="() => this.removeFeeLine(line)">
                                                <i class="fa fa-trash"/>
                                            </button>
                                        </td>
                                    </tr>
                                </t>
                                <tr>
                                    <td>
                                        <select t-model.number="state.newFeeLine.fee_type_id">
                                            <option value="">Choisir un type de frais...</option>
                                            <t t-foreach="state.feeTypes" t-as="ft" t-key="ft.id">
                                                <option t-att-value="ft.id" t-esc="ft.name"/>
                                            </t>
                                        </select>
                                    </td>
                                    <td>
                                        <input type="number" t-model.number="state.newFeeLine.amount"/>
                                    </td>
                                    <td>
                                        <button class="cc-btn-new" t-on-click="addFeeLine">
                                            <i class="fa fa-plus"/>
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </div>

        </div>

        <div t-if="state.activeTab === 'info'" class="cc-pane">
            <div t-if="!state.infoLoaded" class="cc-empty">Chargement...</div>
            <div t-else="" class="cc-form cc-form--info">
                <div class="cc-form-row cc-form-row--logo">
                    <label>Logo</label>
                    <div class="cc-logo-row">
                        <img t-if="state.schoolInfoDraft.logo"
                             t-att-src="'data:image/png;base64,' + state.schoolInfoDraft.logo"
                             class="cc-logo-preview"/>
                        <input type="file" accept="image/*" t-on-change="onLogoChange"/>
                    </div>
                </div>
                <div class="cc-form-row">
                    <label>Nom de l'ecole</label>
                    <input type="text" t-model="state.schoolInfoDraft.name"/>
                </div>
                <div class="cc-form-row">
                    <label>Telephone</label>
                    <input type="text" t-model="state.schoolInfoDraft.phone"/>
                </div>
                <div class="cc-form-row">
                    <label>Email</label>
                    <input type="text" t-model="state.schoolInfoDraft.email"/>
                </div>
                <div class="cc-form-row">
                    <label>Boite postale (BP)</label>
                    <input type="text" t-model="state.schoolInfoDraft.school_po_box"/>
                </div>
                <div class="cc-form-row">
                    <label>Devise de l'ecole (FR)</label>
                    <input type="text" t-model="state.schoolInfoDraft.school_motto"/>
                </div>
                <div class="cc-form-row">
                    <label>Devise de l'ecole (EN)</label>
                    <input type="text" t-model="state.schoolInfoDraft.school_motto_en"/>
                </div>
                <div class="cc-form-row">
                    <label>Delegation regionale</label>
                    <input type="text" t-model="state.schoolInfoDraft.delegation_regionale"/>
                </div>
                <div class="cc-form-row">
                    <label>Delegation departementale</label>
                    <input type="text" t-model="state.schoolInfoDraft.delegation_departementale"/>
                </div>
                <div class="cc-form-row">
                    <label>Autorisation</label>
                    <input type="text" t-model="state.schoolInfoDraft.school_authorization"/>
                </div>
                <div class="cc-form-row cc-form-row--logo">
                    <label>Modele de fond pour les certificats</label>
                    <p class="cc-form-hint">
                        Optionnel : image pleine page (paysage) utilisee a la place du
                        cadre decoratif genere automatiquement sur les certificats de promotion.
                    </p>
                    <div class="cc-logo-row">
                        <img t-if="state.schoolInfoDraft.certificate_background"
                             t-att-src="'data:image/png;base64,' + state.schoolInfoDraft.certificate_background"
                             class="cc-logo-preview"/>
                        <input type="file" accept="image/*" t-on-change="onCertificateBackgroundChange"/>
                        <button t-if="state.schoolInfoDraft.certificate_background"
                                class="cc-btn-cancel" t-on-click="removeCertificateBackground">
                            <i class="fa fa-times"/> Retirer
                        </button>
                    </div>
                </div>
                <div class="cc-form-row cc-form-row--check">
                    <button class="btn btn-sm btn-primary" t-on-click="saveSchoolInfo" t-att-disabled="state.savingInfo">
                        <i class="fa fa-check"/> Enregistrer
                    </button>
                </div>
            </div>
        </div>

        <div t-if="state.activeTab === 'matricule'" class="cc-pane">
            <div t-if="!state.matriculeLoaded" class="cc-empty">Chargement...</div>
            <div t-else="" class="cc-form">
                <div class="cc-form-row cc-form-row--check">
                    <label>
                        <input type="checkbox" t-model="state.matriculeDraft.auto_assign"/>
                        Generer automatiquement le matricule des nouveaux eleves
                    </label>
                </div>
                <div class="cc-form-row">
                    <label>Prefixe par defaut</label>
                    <input type="text" t-model="state.matriculeDraft.prefix"/>
                    <div class="cc-form-hint">
                        Utilise pour les classes sans prefixe propre (onglet Structures,
                        champ "Prefixe matricule" de chaque classe).
                    </div>
                </div>
                <div class="cc-form-row">
                    <label>Nombre de chiffres</label>
                    <input type="number" t-model.number="state.matriculeDraft.padding"/>
                </div>
                <div class="cc-form-row">
                    <label>Prochain numero</label>
                    <input type="number" t-model.number="state.matriculeDraft.number_next"/>
                </div>
                <div class="cc-form-row cc-form-row--check">
                    <button class="btn btn-sm btn-primary" t-on-click="saveMatricule" t-att-disabled="state.savingMatricule">
                        <i class="fa fa-check"/> Enregistrer
                    </button>
                </div>
            </div>
        </div>

        <div t-if="state.activeTab === 'journaux'" class="cc-pane">
            <div t-if="!state.journalsLoaded" class="cc-empty">Chargement...</div>
            <t t-else="">
                <div class="cc-detail-header">
                    <div class="cc-detail-title">Journaux / Caisses</div>
                    <div class="cc-detail-actions">
                        <button class="cc-btn-new" t-on-click="() => this.openJournalForm(false)">
                            <i class="fa fa-plus"/> Nouveau journal
                        </button>
                    </div>
                </div>
                <table class="cc-fees-table">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Code</th>
                            <th>Type</th>
                            <th>Utilise par l'ecole</th>
                            <th/>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.journals" t-as="journal" t-key="journal.id">
                            <tr>
                                <td t-esc="journal.name"/>
                                <td t-esc="journal.code"/>
                                <td t-esc="journalTypeLabel(journal.type)"/>
                                <td>
                                    <input type="checkbox" t-att-checked="journal.school_active"
                                           t-on-change="() => this.toggleJournalActive(journal)"/>
                                </td>
                                <td>
                                    <button class="btn btn-sm" t-on-click="() => this.openJournalForm(journal.id)">
                                        <i class="fa fa-pencil"/>
                                    </button>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </t>
        </div>

        <div t-if="state.activeTab === 'personnel'" class="cc-pane">
            <div t-if="!state.personnelLoaded" class="cc-empty">Chargement...</div>
            <t t-else="">
                <div class="cc-detail-title">Types de personnel</div>
                <table class="cc-fees-table">
                    <thead>
                        <tr><th>Nom</th><th>Code</th><th/></tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.staffTypes" t-as="st" t-key="st.id">
                            <tr>
                                <td t-esc="st.name"/>
                                <td t-esc="st.code || '-'"/>
                                <td>
                                    <button class="cc-btn-danger" t-on-click="() => this.removeStaffType(st)">
                                        <i class="fa fa-trash"/>
                                    </button>
                                </td>
                            </tr>
                        </t>
                        <tr>
                            <td>
                                <input type="text" t-model="state.newStaffTypeName" placeholder="Nouveau type de personnel..."/>
                            </td>
                            <td/>
                            <td>
                                <button class="cc-btn-new" t-on-click="addStaffType">
                                    <i class="fa fa-plus"/>
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="cc-detail-title" style="margin-top: 16px;">Grades</div>
                <table class="cc-fees-table">
                    <thead>
                        <tr><th>Nom</th><th/></tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.grades" t-as="gr" t-key="gr.id">
                            <tr>
                                <td t-esc="gr.name"/>
                                <td>
                                    <button class="cc-btn-danger" t-on-click="() => this.removeGrade(gr)">
                                        <i class="fa fa-trash"/>
                                    </button>
                                </td>
                            </tr>
                        </t>
                        <tr>
                            <td>
                                <input type="text" t-model="state.newGradeName" placeholder="Nouveau grade..."/>
                            </td>
                            <td>
                                <button class="cc-btn-new" t-on-click="addGrade">
                                    <i class="fa fa-plus"/>
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </t>
        </div>

        <div t-if="state.activeTab === 'documents'" class="cc-pane cc-pane--documents">
            <DocTemplates/>
        </div>

        <div t-if="state.activeTab === 'niveaux'" class="cc-pane">
            <div t-if="!state.niveauxLoaded" class="cc-empty">Chargement...</div>
            <t t-else="">
                <p class="cc-form-hint" style="margin-bottom: 12px;">
                    Cliquer sur une ligne pour la modifier.
                </p>

                <div class="cc-detail-title">Cycles</div>
                <table class="cc-fees-table cc-fees-table--ref">
                    <thead><tr><th>Nom</th><th>Code</th><th/></tr></thead>
                    <tbody>
                        <t t-foreach="state.cycles" t-as="cy" t-key="cy.id">
                            <tr t-if="!isEditingRow('cycle', cy.id)" class="cc-row-editable"
                                t-on-click="() => this.startEditRow('cycle', cy)">
                                <td t-esc="cy.name"/>
                                <td t-esc="cy.code"/>
                                <td>
                                    <button class="cc-btn-danger" t-on-click.stop="() => this.removeCycle(cy)">
                                        <i class="fa fa-trash"/>
                                    </button>
                                </td>
                            </tr>
                            <tr t-else="" class="cc-row-editing">
                                <td>
                                    <input type="text" t-model="state.editingRow.draft.name"
                                           t-on-keydown="onEditRowKeydown"/>
                                </td>
                                <td>
                                    <input type="text" t-model="state.editingRow.draft.code"
                                           t-on-keydown="onEditRowKeydown"/>
                                </td>
                                <td>
                                    <button class="cc-btn-new" t-on-click="saveEditRow"><i class="fa fa-check"/></button>
                                    <button class="cc-btn-cancel" t-on-click="cancelEditRow"><i class="fa fa-times"/></button>
                                </td>
                            </tr>
                        </t>
                        <tr>
                            <td><input type="text" t-model="state.newCycleName" placeholder="Nouveau cycle..."/></td>
                            <td/>
                            <td>
                                <button class="cc-btn-new" t-on-click="addCycle"><i class="fa fa-plus"/></button>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="cc-detail-title" style="margin-top: 16px;">Sections / sous-systemes</div>
                <table class="cc-fees-table cc-fees-table--ref">
                    <thead><tr><th>Nom</th><th>Code</th><th/></tr></thead>
                    <tbody>
                        <t t-foreach="state.sections" t-as="se" t-key="se.id">
                            <tr t-if="!isEditingRow('section', se.id)" class="cc-row-editable"
                                t-on-click="() => this.startEditRow('section', se)">
                                <td t-esc="se.name"/>
                                <td t-esc="se.code"/>
                                <td>
                                    <button class="cc-btn-danger" t-on-click.stop="() => this.removeSection(se)">
                                        <i class="fa fa-trash"/>
                                    </button>
                                </td>
                            </tr>
                            <tr t-else="" class="cc-row-editing">
                                <td>
                                    <input type="text" t-model="state.editingRow.draft.name"
                                           t-on-keydown="onEditRowKeydown"/>
                                </td>
                                <td>
                                    <input type="text" t-model="state.editingRow.draft.code"
                                           t-on-keydown="onEditRowKeydown"/>
                                </td>
                                <td>
                                    <button class="cc-btn-new" t-on-click="saveEditRow"><i class="fa fa-check"/></button>
                                    <button class="cc-btn-cancel" t-on-click="cancelEditRow"><i class="fa fa-times"/></button>
                                </td>
                            </tr>
                        </t>
                        <tr>
                            <td><input type="text" t-model="state.newSectionName" placeholder="Nouvelle section..."/></td>
                            <td/>
                            <td>
                                <button class="cc-btn-new" t-on-click="addSection"><i class="fa fa-plus"/></button>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="cc-detail-title" style="margin-top: 16px;">Niveaux</div>
                <table class="cc-fees-table cc-fees-table--niveaux">
                    <thead><tr><th>Nom</th><th>Code</th><th>Cycle</th><th>Section</th><th/></tr></thead>
                    <tbody>
                        <t t-foreach="state.levels" t-as="lv" t-key="lv.id">
                            <tr t-if="!isEditingRow('level', lv.id)" class="cc-row-editable"
                                t-on-click="() => this.startEditRow('level', lv)">
                                <td t-esc="lv.name"/>
                                <td t-esc="lv.code"/>
                                <td t-esc="lv.cycle_id and lv.cycle_id[1]"/>
                                <td t-esc="lv.section_id and lv.section_id[1] or '-'"/>
                                <td>
                                    <button class="cc-btn-danger" t-on-click.stop="() => this.removeLevel(lv)">
                                        <i class="fa fa-trash"/>
                                    </button>
                                </td>
                            </tr>
                            <tr t-else="" class="cc-row-editing">
                                <td>
                                    <input type="text" t-model="state.editingRow.draft.name"
                                           t-on-keydown="onEditRowKeydown"/>
                                </td>
                                <td>
                                    <input type="text" t-model="state.editingRow.draft.code"
                                           t-on-keydown="onEditRowKeydown"/>
                                </td>
                                <td>
                                    <select t-model.number="state.editingRow.draft.cycle_id">
                                        <option value="">-</option>
                                        <t t-foreach="state.cycles" t-as="cy" t-key="cy.id">
                                            <option t-att-value="cy.id" t-esc="cy.name"/>
                                        </t>
                                    </select>
                                </td>
                                <td>
                                    <select t-model.number="state.editingRow.draft.section_id">
                                        <option value="">-</option>
                                        <t t-foreach="state.sections" t-as="se" t-key="se.id">
                                            <option t-att-value="se.id" t-esc="se.name"/>
                                        </t>
                                    </select>
                                </td>
                                <td>
                                    <button class="cc-btn-new" t-on-click="saveEditRow"><i class="fa fa-check"/></button>
                                    <button class="cc-btn-cancel" t-on-click="cancelEditRow"><i class="fa fa-times"/></button>
                                </td>
                            </tr>
                        </t>
                        <tr>
                            <td><input type="text" t-model="state.newLevel.name" placeholder="Ex: CE2"/></td>
                            <td><input type="text" t-model="state.newLevel.code" placeholder="Ex: ce2"/></td>
                            <td>
                                <select t-model.number="state.newLevel.cycle_id">
                                    <option value="">-</option>
                                    <t t-foreach="state.cycles" t-as="cy" t-key="cy.id">
                                        <option t-att-value="cy.id" t-esc="cy.name"/>
                                    </t>
                                </select>
                            </td>
                            <td>
                                <select t-model.number="state.newLevel.section_id">
                                    <option value="">-</option>
                                    <t t-foreach="state.sections" t-as="se" t-key="se.id">
                                        <option t-att-value="se.id" t-esc="se.name"/>
                                    </t>
                                </select>
                            </td>
                            <td>
                                <button class="cc-btn-new" t-on-click="addLevel"><i class="fa fa-plus"/></button>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="cc-detail-title" style="margin-top: 16px;">Series (secondaire)</div>
                <table class="cc-fees-table cc-fees-table--ref">
                    <thead><tr><th>Nom</th><th>Code</th><th/></tr></thead>
                    <tbody>
                        <t t-foreach="state.series" t-as="sr" t-key="sr.id">
                            <tr t-if="!isEditingRow('serie', sr.id)" class="cc-row-editable"
                                t-on-click="() => this.startEditRow('serie', sr)">
                                <td t-esc="sr.name"/>
                                <td t-esc="sr.code"/>
                                <td>
                                    <button class="cc-btn-danger" t-on-click.stop="() => this.removeSerie(sr)">
                                        <i class="fa fa-trash"/>
                                    </button>
                                </td>
                            </tr>
                            <tr t-else="" class="cc-row-editing">
                                <td>
                                    <input type="text" t-model="state.editingRow.draft.name"
                                           t-on-keydown="onEditRowKeydown"/>
                                </td>
                                <td>
                                    <input type="text" t-model="state.editingRow.draft.code"
                                           t-on-keydown="onEditRowKeydown"/>
                                </td>
                                <td>
                                    <button class="cc-btn-new" t-on-click="saveEditRow"><i class="fa fa-check"/></button>
                                    <button class="cc-btn-cancel" t-on-click="cancelEditRow"><i class="fa fa-times"/></button>
                                </td>
                            </tr>
                        </t>
                        <tr>
                            <td><input type="text" t-model="state.newSerieName" placeholder="Nouvelle serie..."/></td>
                            <td/>
                            <td>
                                <button class="cc-btn-new" t-on-click="addSerie"><i class="fa fa-plus"/></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </t>
        </div>

        </div>
    </div>
</t>

</templates>
