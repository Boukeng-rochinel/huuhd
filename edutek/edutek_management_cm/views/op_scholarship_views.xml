<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_op_scholarship_list" model="ir.ui.view">
        <field name="name">op.scholarship.list</field>
        <field name="model">op.scholarship</field>
        <field name="arch" type="xml">
            <list string="Bourses scolaires" decoration-success="state == 'active'" decoration-muted="state == 'ended'">
                <field name="student_id"/>
                <field name="academic_year_id"/>
                <field name="scholarship_type"/>
                <field name="percentage"/>
                <field name="amount"/>
                <field name="date_debut"/>
                <field name="date_fin"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_op_scholarship_form" model="ir.ui.view">
        <field name="name">op.scholarship.form</field>
        <field name="model">op.scholarship</field>
        <field name="arch" type="xml">
            <form string="Bourse scolaire">
                <header>
                    <button name="action_activate" type="object" string="Activer" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_end" type="object" string="Terminer" invisible="state != 'active'"/>
                    <button name="action_print_certificate" string="Imprimer le certificat" type="object"
                            class="btn-primary" invisible="not id"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="student_id" options="{'no_create': True}"/>
                            <field name="academic_year_id"/>
                            <field name="scholarship_type"/>
                        </group>
                        <group>
                            <field name="percentage" invisible="scholarship_type != 'partielle'"/>
                            <field name="amount"/>
                            <field name="date_debut"/>
                            <field name="date_fin"/>
                        </group>
                    </group>
                    <field name="reason" placeholder="Motif de la bourse..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="act_open_op_scholarship_view" model="ir.actions.act_window">
        <field name="name">Bourses scolaires</field>
        <field name="res_model">op.scholarship</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_op_scholarship"
              name="Bourses scolaires"
              parent="edutek_core.menu_op_general_main"
              sequence="20"
              action="act_open_op_scholarship_view"
              groups="edutek_management_cm.group_use_scholarships"/>

</odoo>
