<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form_dashboard_cm" model="ir.ui.view">
        <field name="name">res.company.form.dashboard.cm</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="edutek_core.view_company_form_edutek_core"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='institute_detail']" position="inside">
                <separator string="Structuration"/>
                <field name="op_classroom_count"/>
            </xpath>
        </field>
    </record>

</odoo>
