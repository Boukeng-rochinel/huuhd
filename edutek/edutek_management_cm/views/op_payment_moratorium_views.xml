<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_op_payment_moratorium_list" model="ir.ui.view">
        <field name="name">op.payment.moratorium.list</field>
        <field name="model">op.payment.moratorium</field>
        <field name="arch" type="xml">
            <list string="Moratoires de paiement" decoration-success="state == 'approved'" decoration-muted="state == 'closed'">
                <field name="student_id"/>
                <field name="fee_id"/>
                <field name="original_amount"/>
                <field name="new_due_date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_op_payment_moratorium_form" model="ir.ui.view">
        <field name="name">op.payment.moratorium.form</field>
        <field name="model">op.payment.moratorium</field>
        <field name="arch" type="xml">
            <form string="Moratoire de paiement">
                <header>
                    <button name="action_approve" type="object" string="Approuver" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" type="object" string="Cloturer" invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="fee_id" options="{'no_create': True}"/>
                            <field name="student_id"/>
                            <field name="original_amount"/>
                        </group>
                        <group>
                            <field name="new_due_date"/>
                            <field name="decision_date"/>
                        </group>
                    </group>
                    <field name="reason" placeholder="Motif du moratoire..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="act_open_op_payment_moratorium_view" model="ir.actions.act_window">
        <field name="name">Moratoires de paiement</field>
        <field name="res_model">op.payment.moratorium</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_op_payment_moratorium"
              name="Moratoires de paiement"
              parent="edutek_core.menu_op_general_main"
              sequence="40"
              action="act_open_op_payment_moratorium_view"
              groups="edutek_management_cm.group_use_moratoriums"/>

</odoo>
