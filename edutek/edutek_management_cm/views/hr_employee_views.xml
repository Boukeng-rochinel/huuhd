<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_employee_form_inherit_sis_pin" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.sis.pin</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- Ajoute un onglet dedie plutot que chercher une page par nom -->
            <xpath expr="//notebook" position="inside">
                <page string="Securite EduTek" name="sis_security"
                      groups="hr.group_hr_manager,base.group_system">
                    <group>
                        <field name="sis_role"/>
                        <field name="sis_pin"
                               password="True"
                               placeholder="4 a 6 chiffres"
                               help="Code PIN utilise pour deverrouiller l'ecran EduTek."/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
