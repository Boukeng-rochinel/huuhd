<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_op_admission_application_list" model="ir.ui.view">
        <field name="name">op.admission.application.list</field>
        <field name="model">op.admission.application</field>
        <field name="arch" type="xml">
            <list string="Candidatures" decoration-success="state == 'accepted'" decoration-danger="state == 'rejected'">
                <field name="applicant_name"/>
                <field name="desired_classe_id"/>
                <field name="application_date"/>
                <field name="parent_name"/>
                <field name="parent_phone"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_op_admission_application_form" model="ir.ui.view">
        <field name="name">op.admission.application.form</field>
        <field name="model">op.admission.application</field>
        <field name="arch" type="xml">
            <form string="Candidature">
                <header>
                    <button name="action_accept" type="object" string="Accepter" class="btn-primary" invisible="state != 'pending'"/>
                    <button name="action_reject" type="object" string="Rejeter" invisible="state != 'pending'"/>
                    <button name="action_create_student" type="object" string="Creer l'eleve" class="btn-primary" invisible="state != 'accepted' or student_id"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="applicant_name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="birth_date"/>
                            <field name="gender"/>
                            <field name="desired_classe_id" options="{'no_create': True}"/>
                            <field name="academic_year_id"/>
                        </group>
                        <group>
                            <field name="parent_name"/>
                            <field name="parent_phone"/>
                            <field name="parent_email"/>
                            <field name="application_date"/>
                            <field name="decision_date" readonly="1"/>
                            <field name="student_id" readonly="1" invisible="not student_id"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Note..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="act_open_op_admission_application_view" model="ir.actions.act_window">
        <field name="name">Candidatures</field>
        <field name="res_model">op.admission.application</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_op_admission_application"
              name="Candidatures"
              parent="edutek_core.menu_op_general_main"
              sequence="10"
              action="act_open_op_admission_application_view"
              groups="edutek_management_cm.group_use_admissions"/>

</odoo>
