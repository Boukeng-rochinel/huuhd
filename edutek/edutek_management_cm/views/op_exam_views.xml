<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_op_exam_list" model="ir.ui.view">
        <field name="name">op.exam.list</field>
        <field name="model">op.exam</field>
        <field name="arch" type="xml">
            <list string="Examens &amp; Concours">
                <field name="date"/>
                <field name="name"/>
                <field name="exam_type"/>
                <field name="classe_id"/>
                <field name="academic_year_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_op_exam_form" model="ir.ui.view">
        <field name="name">op.exam.form</field>
        <field name="model">op.exam</field>
        <field name="arch" type="xml">
            <form string="Examen / Concours">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="exam_type"/>
                            <field name="classe_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="academic_year_id"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Note..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_op_exam_search" model="ir.ui.view">
        <field name="name">op.exam.search</field>
        <field name="model">op.exam</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="classe_id"/>
                <filter name="examens" string="Examens" domain="[('exam_type', '=', 'examen')]"/>
                <filter name="concours" string="Concours" domain="[('exam_type', '=', 'concours')]"/>
                <separator/>
                <filter name="group_type" string="Type" context="{'group_by': 'exam_type'}"/>
                <filter name="group_classe" string="Classe" context="{'group_by': 'classe_id'}"/>
            </search>
        </field>
    </record>

    <record id="act_open_op_exam_view" model="ir.actions.act_window">
        <field name="name">Examens &amp; Concours</field>
        <field name="res_model">op.exam</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_op_exam"
              name="Examens &amp; Concours"
              parent="edutek_core.menu_op_school_config"
              sequence="40"
              action="act_open_op_exam_view"
              groups="edutek_core.group_op_back_office_admin,edutek_core.group_op_faculty"/>

</odoo>
