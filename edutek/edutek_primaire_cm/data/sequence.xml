<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_op_student_fee" model="ir.sequence">
        <field name="name">Frais Eleve</field>
        <field name="code">op.student.fee</field>
        <field name="prefix">FRAIS-%(year)s-</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_op_bank_receipt" model="ir.sequence">
        <field name="name">Reçu Bancaire</field>
        <field name="code">op.bank.receipt</field>
        <field name="prefix">REC-%(year)s-</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_op_student_gr_no" model="ir.sequence">
        <field name="name">Matricule eleve</field>
        <field name="code">op.student.gr_no</field>
        <field name="prefix"></field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
