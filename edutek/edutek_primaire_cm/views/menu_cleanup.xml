<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════
         Nettoyage du menu EduTek : masque les menus
         generiques non utilises par le workflow
         camerounais, sans toucher aux fichiers
         d'origine (non destructif - active=False).
    ══════════════════════════════════════════ -->

    <!-- Ancienne app "Students" (Profile / Subject Registration / Student
         Course Detail) - fait doublon avec EduTek > Etudiants ; ses sous-
         fonctionnalites (op.student.course, op.subject.registration) ne
         sont pas utilisees par le primaire/secondaire/maternelle CM. -->
    <record id="edutek_core.menu_op_student_root" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- "Faculties" (op.faculty) fait doublon avec "Personnel" (hr.employee,
         le veritable dossier du personnel utilise par classe_id.teacher_id
         et enrichi des champs camerounais). -->
    <record id="edutek_core.menu_op_faculty_main" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Gestion des cours/lots/departements (op.course/op.batch/
         op.department) : concepts generiques non utilises - le
         primaire/secondaire/maternelle CM repose entierement sur
         op.classe. -->
    <record id="edutek_core.menu_op_school_config_course" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Gestion des programmes/niveaux de programme (op.program/
         op.program.level) : meme constat, non utilise. -->
    <record id="edutek_core.menu_op_school_config_program" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- "Activity Management" : sous-menu vide (aucune fonctionnalite
         camerounaise ne s'y rattache) - cache plutot que de laisser un
         element de menu qui ne menerait a rien. -->
    <record id="edutek_core.menu_op_school_config_activity" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- ══════════════════════════════════════════
         Aplatissement : "Subject Management" et "General
         Management" n'avaient qu'un seul enfant chacun -
         on remonte directement Matieres/Categories sous
         Configuration et on masque les sous-menus devenus
         vides, pour eviter un niveau de clic inutile.
    ══════════════════════════════════════════ -->
    <record id="edutek_core.menu_op_subject_sub" model="ir.ui.menu">
        <field name="name">Matieres</field>
        <field name="parent_id" ref="edutek_core.menu_op_school_config"/>
        <field name="sequence">70</field>
    </record>
    <record id="edutek_core.menu_op_school_config_subject" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <record id="edutek_core.menu_op_category_sub" model="ir.ui.menu">
        <field name="parent_id" ref="edutek_core.menu_op_school_config"/>
        <field name="sequence">80</field>
    </record>
    <record id="edutek_core.menu_op_school_config_general" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- ══════════════════════════════════════════
         Renommages pour des libelles plus parlants.
    ══════════════════════════════════════════ -->
    <record id="edutek_core.menu_op_school_main" model="ir.ui.menu">
        <field name="name">Etudiants</field>
    </record>
    <record id="edutek_core.menu_op_general_main" model="ir.ui.menu">
        <field name="name">Vie scolaire</field>
    </record>
    <record id="edutek_core.menu_op_report_main" model="ir.ui.menu">
        <field name="name">Rapports</field>
    </record>

    <!-- ══════════════════════════════════════════
         Ordre des 8 menus principaux de l'app EduTek :
         d'abord ce qui se consulte/saisit au quotidien
         (eleves, classes, pedagogie, finances, personnel),
         puis ce qui est plus occasionnel (vie scolaire,
         rapports), Configuration toujours en dernier.
    ══════════════════════════════════════════ -->
    <record id="edutek_core.menu_op_school_main" model="ir.ui.menu">
        <field name="sequence">10</field>
    </record>
    <record id="menu_op_classe_root" model="ir.ui.menu">
        <field name="sequence">20</field>
    </record>
    <record id="menu_op_pedagogie" model="ir.ui.menu">
        <field name="sequence">30</field>
    </record>
    <record id="menu_op_frais" model="ir.ui.menu">
        <field name="sequence">40</field>
    </record>
    <record id="menu_op_hr_employee" model="ir.ui.menu">
        <field name="sequence">50</field>
    </record>
    <record id="edutek_core.menu_op_general_main" model="ir.ui.menu">
        <field name="sequence">60</field>
    </record>
    <record id="edutek_core.menu_op_report_main" model="ir.ui.menu">
        <field name="sequence">70</field>
    </record>
    <record id="edutek_core.menu_op_school_config" model="ir.ui.menu">
        <field name="sequence">80</field>
    </record>

    <!-- ══════════════════════════════════════════
         Pedagogie : separe le suivi Primaire/Secondaire
         (Notes & Bulletins) du suivi Maternelle (acquis/
         carnets, regroupe depuis edutek_maternelle_cm dans
         son propre fichier - meme contrainte de dependance
         que plus haut).
    ══════════════════════════════════════════ -->
    <menuitem id="menu_op_pedagogie_notes_bulletins"
              name="Notes &amp; Bulletins"
              parent="menu_op_pedagogie"
              sequence="10"/>

    <record id="menu_op_student_mark_generate" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_pedagogie_notes_bulletins"/>
        <field name="sequence">10</field>
    </record>
    <record id="menu_op_student_mark" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_pedagogie_notes_bulletins"/>
        <field name="sequence">20</field>
    </record>
    <record id="menu_op_student_mark_list_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_pedagogie_notes_bulletins"/>
        <field name="sequence">30</field>
    </record>
    <record id="menu_op_bulletin_generate" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_pedagogie_notes_bulletins"/>
        <field name="sequence">40</field>
    </record>
    <record id="menu_op_bulletin" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_pedagogie_notes_bulletins"/>
        <field name="sequence">50</field>
    </record>
    <record id="menu_op_bulletin_list_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_pedagogie_notes_bulletins"/>
        <field name="sequence">60</field>
    </record>

    <!-- ══════════════════════════════════════════
         Finances : regroupe les etats/listes en lecture
         (insolvables, encaissements, liste des frais), pour
         ne laisser au premier niveau que les 4 actions
         vraiment utilisees au quotidien.
    ══════════════════════════════════════════ -->
    <menuitem id="menu_op_finances_etats"
              name="Etats &amp; rapports"
              parent="menu_op_frais"
              sequence="50"/>

    <record id="menu_op_student_insolvable" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_finances_etats"/>
        <field name="sequence">10</field>
    </record>
    <record id="menu_op_cash_collection_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_finances_etats"/>
        <field name="sequence">20</field>
    </record>
    <record id="menu_op_student_fee_list_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_finances_etats"/>
        <field name="sequence">30</field>
    </record>

    <!-- ══════════════════════════════════════════
         Rapports : regroupe les 4 assistants "Liste de X"
         (meme nature - generation d'une liste imprimable/
         exportable) sous un seul sous-menu, distinct des
         "Etats generaux" (etat global) et de l'"Historique
         des inscriptions" (consultation directe, pas un
         assistant de generation).
    ══════════════════════════════════════════ -->
    <menuitem id="menu_op_rapports_listes"
              name="Listes"
              parent="edutek_core.menu_op_report_main"
              sequence="20"/>

    <record id="menu_op_student_list_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_rapports_listes"/>
        <field name="sequence">10</field>
    </record>
    <record id="menu_op_student_registration_list_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_rapports_listes"/>
        <field name="sequence">20</field>
    </record>
    <record id="menu_op_employee_list_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_rapports_listes"/>
        <field name="sequence">30</field>
    </record>
    <record id="menu_op_classe_list_wizard" model="ir.ui.menu">
        <field name="parent_id" ref="menu_op_rapports_listes"/>
        <field name="sequence">40</field>
    </record>

    <!-- ══════════════════════════════════════════
         Sequences propres pour les elements de Configuration
         definis dans edutek_core lui-meme (les elements definis
         dans d'autres modules - classe_config_cm, doc_templates_cm,
         student_registry_cm - sont renumerotes directement dans
         leur propre fichier : edutek_primaire_cm ne peut pas les
         referencer ici sans creer une dependance circulaire, ces
         modules dependant tous d'edutek_primaire_cm).
    ══════════════════════════════════════════ -->
    <record id="edutek_core.menu_academic_year" model="ir.ui.menu">
        <field name="sequence">50</field>
    </record>
    <record id="edutek_core.menu_academic_term" model="ir.ui.menu">
        <field name="sequence">60</field>
    </record>
    <record id="edutek_core.menu_edutek_config" model="ir.ui.menu">
        <field name="sequence">90</field>
    </record>
    <record id="menu_op_student_import_wizard" model="ir.ui.menu">
        <field name="sequence">100</field>
    </record>

</odoo>
