<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════
         KANBAN VIEW
    ══════════════════════════════════════════ -->
    <record id="view_op_classe_kanban" model="ir.ui.view">
        <field name="name">op.classe.kanban</field>
        <field name="model">op.classe</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="student_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click p-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <strong class="o_kanban_record_title fs-5">
                                    <field name="display_name"/>
                                </strong>
                                <span class="badge text-bg-primary">
                                    <field name="level"/>
                                </span>
                            </div>
                            <div class="text-muted">
                                <field name="academic_year_id"/>
                            </div>
                            <div class="mt-1" t-if="record.teacher_id.value">
                                <i class="fa fa-user-o me-1" title="Enseignant"/>
                                <field name="teacher_id"/>
                            </div>
                            <div class="mt-2">
                                <i class="fa fa-users me-1" title="Eleves"/>
                                <field name="student_count"/> eleve(s)
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══════════════════════════════════════════
         LIST VIEW
    ══════════════════════════════════════════ -->
    <record id="view_op_classe_list" model="ir.ui.view">
        <field name="name">op.classe.list</field>
        <field name="model">op.classe</field>
        <field name="arch" type="xml">
            <list string="Classes">
                <field name="name"/>
                <field name="level"/>
                <field name="academic_year_id"/>
                <field name="teacher_id" optional="show"/>
                <field name="student_count" string="Eleves"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════
         FORM VIEW
    ══════════════════════════════════════════ -->
    <record id="view_op_classe_form" model="ir.ui.view">
        <field name="name">op.classe.form</field>
        <field name="model">op.classe</field>
        <field name="arch" type="xml">
            <form string="Classe">
                <header>
                    <button name="action_open_mark_generate_wizard" type="object"
                            string="Saisir les notes" class="btn-secondary"
                            invisible="not id"/>
                    <button name="action_open_bulletin_generate_wizard" type="object"
                            string="Generer les bulletins" class="btn-secondary"
                            invisible="not id"
                            groups="edutek_core.group_op_back_office_admin"/>
                    <button name="action_open_fee_generate_wizard" type="object"
                            string="Generer des frais" class="btn-secondary"
                            invisible="not id"
                            groups="edutek_core.group_op_back_office_admin"/>
                    <button name="action_open_student_list_wizard" type="object"
                            string="Imprimer la liste des eleves" class="btn-secondary"
                            invisible="not id"/>
                    <button name="action_open_insolvable_wizard" type="object"
                            string="Etat des insolvables" class="btn-secondary"
                            invisible="not id"
                            groups="edutek_core.group_op_back_office_admin"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-users"
                                type="object" name="action_view_students">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="student_count" nolabel="1"/>
                                </span>
                                <span class="o_stat_text">Eleves</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-pencil-square-o"
                                type="object" name="action_view_marks">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="mark_count" nolabel="1"/>
                                </span>
                                <span class="o_stat_text">Notes</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-graduation-cap"
                                type="object" name="action_view_bulletins">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="bulletin_count" nolabel="1"/>
                                </span>
                                <span class="o_stat_text">Bulletins</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-money"
                                type="object" name="action_view_fees_unpaid"
                                groups="edutek_core.group_op_back_office_admin">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="fee_unpaid_count" nolabel="1"/>
                                </span>
                                <span class="o_stat_text">Frais impayes</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ex: CM2 A"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="level"/>
                            <field name="academic_year_id"/>
                        </group>
                        <group>
                            <field name="teacher_id"/>
                            <field name="matricule_prefix" placeholder="Ex: CE2"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Programme (matieres et coefficients)" name="programme">
                            <field name="subject_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="subject_id"/>
                                    <field name="coefficient"/>
                                </list>
                            </field>
                        </page>
                        <page string="Frais configures" name="frais"
                              groups="edutek_core.group_op_back_office_admin">
                            <field name="fee_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="fee_type_id" options="{'no_create': True}"/>
                                    <field name="amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <p class="text-muted">
                                Ces frais sont automatiquement affectes et facture (comptabilises)
                                a chaque eleve inscrit dans cette classe, des que le montant ci-dessus
                                est strictement positif. Une ligne a 0 est ignoree jusqu'a ce qu'un
                                montant soit renseigne.
                            </p>
                        </page>
                        <page string="Periodes" name="periodes">
                            <field name="applicable_term_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </page>
                        <page string="Eleves" name="eleves">
                            <field name="student_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="gr_no"/>
                                    <field name="gender"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════
         SEARCH VIEW
    ══════════════════════════════════════════ -->
    <record id="view_op_classe_search" model="ir.ui.view">
        <field name="name">op.classe.search</field>
        <field name="model">op.classe</field>
        <field name="arch" type="xml">
            <search string="Classes">
                <field name="name"/>
                <field name="level"/>
                <field name="academic_year_id"/>
                <field name="teacher_id"/>
                <group>
                    <filter name="group_level" string="Niveau" context="{'group_by': 'level'}"/>
                    <filter name="group_year" string="Annee academique" context="{'group_by': 'academic_year_id'}"/>
                    <filter name="group_teacher" string="Enseignant" context="{'group_by': 'teacher_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════
         ACTION + MENU
    ══════════════════════════════════════════ -->
    <!-- Action generale (toutes classes, utile en interne) -->
    <record id="action_op_classe" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">op.classe</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_op_classe_search"/>
    </record>

    <!-- Action filtree : Primaire uniquement -->
    <record id="action_op_classe_primaire" model="ir.actions.act_window">
        <field name="name">Primaire</field>
        <field name="res_model">op.classe</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_op_classe_search"/>
        <field name="domain">[('level', 'in', ['sil','cp','ce1','ce2','cm1','cm2','class1','class2','class3','class4','class5','class6'])]</field>
    </record>

    <!-- Menu parent "Classes" (sans action directe) -->
    <menuitem id="menu_op_classe_root"
              name="Classes"
              parent="edutek_core.menu_op_school_root"
              sequence="15"
              groups="edutek_core.group_op_faculty"/>

    <!-- Sous-menu Primaire -->
    <menuitem id="menu_op_classe_primaire"
              name="Primaire"
              parent="menu_op_classe_root"
              action="action_op_classe_primaire"
              sequence="20"
              groups="edutek_core.group_op_faculty"/>

    <!-- Alias pour compatibilite (ancienne ref menu_op_classe) -->
    <menuitem id="menu_op_classe"
              name="Toutes les classes"
              parent="menu_op_classe_root"
              action="action_op_classe"
              sequence="90"
              groups="edutek_core.group_op_back_office_admin"/>

</odoo>
