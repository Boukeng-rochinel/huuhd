<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_op_student_registration_list_wizard_form" model="ir.ui.view">
        <field name="name">op.student.registration.list.wizard.form</field>
        <field name="model">op.student.registration.list.wizard</field>
        <field name="arch" type="xml">
            <form string="Liste des eleves inscrits">
                <header>
                    <button name="action_print_pdf" type="object"
                            string="Imprimer (PDF)" class="btn-primary"/>
                </header>
                <sheet>
                    <p class="text-muted">
                        Imprime la liste des eleves inscrits sur une periode
                        donnee, regroupee par classe.
                    </p>
                    <group>
                        <group>
                            <field name="academic_year_id" options="{'no_create': True}"/>
                            <field name="classe_ids" widget="many2many_tags"
                                   options="{'no_create': True}"
                                   placeholder="Toutes les classes si vide"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="preview_count" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_op_student_registration_list_wizard" model="ir.actions.act_window">
        <field name="name">Liste des eleves inscrits</field>
        <field name="res_model">op.student.registration.list.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <menuitem id="menu_op_student_registration_list_wizard"
              name="Liste des eleves inscrits"
              parent="edutek_core.menu_op_report_main"
              action="action_op_student_registration_list_wizard"
              sequence="20"
              groups="edutek_core.group_op_faculty"/>

</odoo>
