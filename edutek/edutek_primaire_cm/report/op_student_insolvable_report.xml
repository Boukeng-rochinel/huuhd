<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_op_student_insolvable" model="ir.actions.report">
        <field name="name">Etat des insolvables</field>
        <field name="model">op.student.insolvable.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">edutek_primaire_cm.student_insolvable</field>
        <field name="report_file">edutek_primaire_cm.student_insolvable</field>
        <field name="print_report_name">'Etat des insolvables'</field>
        <field name="paperformat_id" ref="paperformat_school_document"/>
    </record>

    <template id="student_insolvable">
        <t t-call="web.html_container">
            <div class="page">
                <div style="display: flex; justify-content: space-between; font-size: 11px;">
                    <div><strong>Annee scolaire :</strong> <span t-esc="docs.academic_year_id.name"/></div>
                    <div style="text-align: right;"><strong>Imprime le</strong> <span t-esc="now"/></div>
                </div>

                <t t-call="edutek_primaire_cm.report_school_letterhead"/>

                <t t-set="doc_title" t-value="'ETAT DES INSOLVABLES'"/>
                <t t-call="edutek_primaire_cm.report_school_doc_title"/>

                <t t-foreach="groups" t-as="group">
                    <div style="color: #2a5db0; font-weight: bold; font-size: 13px; margin-top: 16px;">
                        <t t-esc="group['classe'].display_name or 'Sans classe'"/>
                    </div>
                    <table style="width: 100%; border-collapse: collapse; font-size: 10px; margin-top: 6px;">
                        <t t-set="table_headers" t-value="['N°', 'Matricule', &quot;Nom de l'eleve&quot;, 'Montant du', 'Montant verse', 'Reste']"/>
                        <t t-call="edutek_primaire_cm.report_school_table_head"/>
                        <tbody>
                            <t t-foreach="group['lines']" t-as="line" t-key="line_index">
                                <tr t-att-style="'background: #f5f5f5;' if line_index % 2 else ''">
                                    <td style="border: 1px solid #999; padding: 4px 6px; text-align: center;" t-esc="line_index + 1"/>
                                    <td style="border: 1px solid #999; padding: 4px 6px;"><t t-esc="line['matricule']"/></td>
                                    <td style="border: 1px solid #999; padding: 4px 6px;"><t t-esc="line['student'].name"/></td>
                                    <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;"><t t-esc="'{:,.0f}'.format(line['montant_du']).replace(',', ' ')"/></td>
                                    <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;"><t t-esc="'{:,.0f}'.format(line['montant_verse']).replace(',', ' ')"/></td>
                                    <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;"><t t-esc="'{:,.0f}'.format(line['reste']).replace(',', ' ')"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

                <p t-if="not groups" style="text-align: center; color: #6c757d;">
                    Aucun eleve insolvable ne correspond a ces criteres.
                </p>
                <table t-if="groups" style="width: 100%; border-collapse: collapse; font-size: 11px; margin-top: 12px;">
                    <tr style="font-weight: bold; background:#eee;">
                        <td style="border: 1px solid #999; padding: 4px 6px;">Effectif : <span t-esc="effectif"/></td>
                        <td style="border: 1px solid #999; padding: 4px 6px;">TOTAL</td>
                        <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;"><t t-esc="'{:,.0f}'.format(total_du).replace(',', ' ')"/></td>
                        <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;"><t t-esc="'{:,.0f}'.format(total_verse).replace(',', ' ')"/></td>
                        <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;"><t t-esc="'{:,.0f}'.format(total_reste).replace(',', ' ')"/></td>
                    </tr>
                </table>

                <t t-call="edutek_primaire_cm.report_school_footer"/>
            </div>
        </t>
    </template>

</odoo>
