<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_op_bulletin_list" model="ir.actions.report">
        <field name="name">Classement des bulletins</field>
        <field name="model">op.bulletin.list.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">edutek_primaire_cm.report_bulletin_list_document</field>
        <field name="report_file">edutek_primaire_cm.report_bulletin_list_document</field>
        <field name="print_report_name">'Classement des bulletins'</field>
        <field name="paperformat_id" ref="paperformat_school_document"/>
    </record>

    <template id="report_bulletin_list_document">
        <t t-call="web.html_container">
            <div class="page">
                <div style="text-align: right; font-size: 11px;">
                    <strong>Date / Heure :</strong> <span t-esc="now"/>
                </div>

                <t t-call="edutek_primaire_cm.report_school_letterhead"/>

                <t t-set="doc_title" t-value="'CLASSEMENT DES BULLETINS'"/>
                <t t-call="edutek_primaire_cm.report_school_doc_title"/>

                <table style="width: 100%; border-collapse: collapse; font-size: 17px;">
                    <t t-set="table_headers" t-value="['Rang', 'Eleve', 'Classe', 'Moyenne', 'Appreciation', 'Conduite']"/>
                    <t t-call="edutek_primaire_cm.report_school_table_head"/>
                    <tbody>
                        <t t-foreach="bulletins" t-as="bulletin" t-key="bulletin.id">
                            <tr t-att-style="'background: #f5f5f5;' if bulletin_index % 2 else ''">
                                <td style="border: 1px solid #999; padding: 4px 6px; text-align: center;" t-esc="bulletin.rang"/>
                                <td style="border: 1px solid #999; padding: 4px 6px;" t-esc="bulletin.student_id.name"/>
                                <td style="border: 1px solid #999; padding: 4px 6px;" t-esc="bulletin.classe_id.display_name or ''"/>
                                <td style="border: 1px solid #999; padding: 4px 6px; text-align: center;" t-esc="'%.2f' % bulletin.moyenne_generale"/>
                                <td style="border: 1px solid #999; padding: 4px 6px;" t-esc="bulletin.appreciation or ''"/>
                                <td style="border: 1px solid #999; padding: 4px 6px;" t-esc="conduite_labels.get(bulletin.conduite, bulletin.conduite or '')"/>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <p t-if="not bulletins" style="text-align: center; color: #6c757d; margin-top: 16px;">
                    Aucun bulletin ne correspond a ces criteres.
                </p>
                <div t-else="" style="margin-top: 12px; font-size: 17px;">
                    <strong>Nombre de bulletins :</strong> <span t-esc="len(bulletins)"/>
                </div>

                <t t-call="edutek_primaire_cm.report_school_footer"/>
            </div>
        </t>
    </template>

</odoo>
