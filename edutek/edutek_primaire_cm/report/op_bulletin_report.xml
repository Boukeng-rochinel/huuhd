<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_op_bulletin" model="ir.actions.report">
        <field name="name">Bulletin trimestriel</field>
        <field name="model">op.bulletin</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">edutek_primaire_cm.report_bulletin_document</field>
        <field name="report_file">edutek_primaire_cm.report_bulletin_document</field>
        <field name="print_report_name">'Bulletin - %s - %s' % (object.student_id.name, object.academic_term_id.name)</field>
        <field name="binding_model_id" ref="model_op_bulletin"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_school_document"/>
    </record>

    <template id="report_bulletin_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="page">
                    <t t-call="edutek_primaire_cm.report_school_letterhead"/>

                    <h2 class="text-center mt-3">Bulletin Trimestriel</h2>
                    <div class="row mt-4">
                        <div class="col-6">
                            <strong>Eleve :</strong> <span t-field="o.student_id.name"/><br/>
                            <strong>Classe :</strong> <span t-field="o.classe_id.name"/><br/>
                        </div>
                        <div class="col-6">
                            <strong>Annee academique :</strong> <span t-field="o.academic_year_id.name"/><br/>
                            <strong>Periode :</strong> <span t-field="o.academic_term_id.name"/><br/>
                        </div>
                    </div>

                    <table class="table table-bordered mt-4">
                        <thead>
                            <tr>
                                <th>Matiere</th>
                                <th class="text-center">Coef</th>
                                <th class="text-center">Note / 20</th>
                                <th class="text-center">Note x Coef</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.line_ids" t-as="line">
                                <td><span t-field="line.subject_id.name"/></td>
                                <td class="text-center">
                                    <span t-field="line.coefficient" t-options="{'widget': 'float', 'precision': 1}"/>
                                </td>
                                <td class="text-center">
                                    <span t-field="line.note" t-options="{'widget': 'float', 'precision': 2}"/>
                                </td>
                                <td class="text-center">
                                    <span t-field="line.note_x_coef" t-options="{'widget': 'float', 'precision': 2}"/>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <th>Total</th>
                                <th class="text-center">
                                    <span t-field="o.total_coef" t-options="{'widget': 'float', 'precision': 1}"/>
                                </th>
                                <th/>
                                <th class="text-center">
                                    <span t-field="o.total_points" t-options="{'widget': 'float', 'precision': 2}"/>
                                </th>
                            </tr>
                        </tfoot>
                    </table>

                    <div class="row mt-4">
                        <div class="col-6">
                            <strong>Moyenne generale :</strong>
                            <span t-field="o.moyenne_generale" t-options="{'widget': 'float', 'precision': 2}"/> / 20<br/>
                            <strong>Rang :</strong>
                            <span t-field="o.rang"/> / <span t-field="o.effectif_classe"/><br/>
                            <strong>Moyenne de la classe :</strong>
                            <span t-field="o.moyenne_classe" t-options="{'widget': 'float', 'precision': 2}"/> / 20<br/>
                        </div>
                        <div class="col-6">
                            <strong>Conduite :</strong> <span t-field="o.conduite"/><br/>
                            <strong>Absences justifiees :</strong> <span t-field="o.absences_justifiees"/><br/>
                            <strong>Absences injustifiees :</strong> <span t-field="o.absences_injustifiees"/><br/>
                        </div>
                    </div>

                    <div class="mt-4">
                        <strong>Appreciation generale :</strong> <span t-field="o.appreciation"/><br/>
                        <strong>Decision :</strong> <span t-field="o.decision"/><br/>
                    </div>

                    <div class="row" style="margin-top: 60px;">
                        <div class="col-4 text-center">
                            Le Maitre / La Maitresse
                        </div>
                        <div class="col-4 text-center">
                            Le Directeur
                        </div>
                        <div class="col-4 text-center">
                            Le Parent
                        </div>
                    </div>

                    <t t-call="edutek_primaire_cm.report_school_footer"/>
                </div>
            </t>
        </t>
    </template>

</odoo>
