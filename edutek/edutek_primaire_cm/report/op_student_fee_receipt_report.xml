<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Format A4 dedie : ce rapport n'utilise pas web.external_layout
         (pas d'en-tete/pied de page QWeb), donc pas besoin des grandes
         marges reservees de base.paperformat_euro (40mm/32mm) - elles ne
         servaient qu'a faire de la place a un en-tete jamais affiche ici,
         et reduisaient d'autant la place disponible pour les deux
         exemplaires du recu sur la page A4. -->
    <record id="paperformat_student_fee_receipt" model="report.paperformat">
        <field name="name">Recu de paiement (A4 plein)</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">6</field>
        <field name="margin_right">6</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_op_student_fee_receipt" model="ir.actions.report">
        <field name="name">Recu de paiement</field>
        <field name="model">op.student.fee</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">edutek_primaire_cm.report_student_fee_receipt_document</field>
        <field name="report_file">edutek_primaire_cm.report_student_fee_receipt_document</field>
        <field name="print_report_name">'%s - Recu %s - %s' % (object.company_id.name, object.student_id.name, object.name)</field>
        <field name="binding_model_id" ref="model_op_student_fee"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_student_fee_receipt"/>
    </record>

    <!-- ══════════════════════════════════════════
         CORPS DU RECU (appele deux fois par page A4 :
         un exemplaire pour l'ecole, un pour le payeur).
         Tailles calibrees pour que les deux exemplaires
         tiennent sur une seule page A4 meme avec 3-4
         tranches de frais dans le tableau recapitulatif -
         au-dela, le second exemplaire peut deborder sur une
         2e page (pas de saut de page force ici), ce qui reste
         correct, juste moins economique en papier.
    ══════════════════════════════════════════ -->
    <template id="report_student_fee_receipt_body">
        <t t-set="company" t-value="o.company_id"/>
        <t t-set="last_pay" t-value="o._get_last_payment()"/>
        <t t-set="montant_verse" t-value="last_pay.amount if last_pay and last_pay.id else (o.amount - o.amount_residual)"/>
        <t t-set="mode_paiement" t-value="(last_pay.journal_id.name if last_pay and last_pay.id else o.journal_id.name) or ''"/>
        <t t-set="recap_lines" t-value="o._get_recap_lines()"/>
        <t t-set="total_tarif" t-value="sum(l['tarif'] for l in recap_lines)"/>
        <t t-set="total_paye" t-value="sum(l['paye'] for l in recap_lines)"/>
        <t t-set="total_reste" t-value="sum(l['reste'] for l in recap_lines)"/>
        <t t-set="qr_b64" t-value="o._get_qr_code_b64()"/>

        <div style="border: 1px solid #333; padding: 10px 16px; font-size: 14px;
                    font-family: 'DejaVu Sans', Arial, sans-serif; color: #111;
                    height: 100%; box-sizing: border-box;">

            <div style="text-align: center; font-size: 11px; font-weight: bold;
                        letter-spacing: 0.5px; color: #555; margin-bottom: 4px;">
                <t t-esc="copy_label"/>
            </div>

            <!-- En-tete bilingue (Republique du Cameroun) + logo + ecole + numero -->
            <table style="width:100%; border-collapse: collapse; margin-bottom: 4px;">
                <tr>
                    <td style="width: 30%; text-align: center; vertical-align: middle;
                               font-size: 10px; line-height: 1.3;">
                        <strong>REPUBLIQUE DU CAMEROUN</strong><br/>
                        Paix - Travail - Patrie
                    </td>
                    <td style="width: 16%; text-align: center; vertical-align: middle;">
                        <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                             style="max-height: 50px; max-width: 90px;"/>
                    </td>
                    <td style="width: 30%; text-align: center; vertical-align: middle;
                               font-size: 10px; line-height: 1.3;">
                        <strong>REPUBLIC OF CAMEROON</strong><br/>
                        Peace - Work - Fatherland
                    </td>
                </tr>
            </table>
            <div style="text-align: center; margin-bottom: 4px;">
                <div style="font-weight: bold; font-size: 16px; text-transform: uppercase;">
                    <t t-esc="company.name"/>
                </div>
                <div style="font-size: 11px; color: #444;">
                    <t t-if="company.phone">Tel : <t t-esc="company.phone"/></t>
                    <t t-if="company.email"> - Email : <t t-esc="company.email"/></t>
                    <t t-if="company.city"> - <t t-esc="company.city"/></t>
                </div>
            </div>

            <table style="width:100%; border-collapse: collapse; border-top: 1px solid #333;
                        border-bottom: 1px solid #333; margin-bottom: 8px;">
                <tr>
                    <td style="text-align: center; padding: 4px 0; font-weight: bold;
                               font-size: 18px; letter-spacing: 1px;">
                        RECU DE PAIEMENT
                    </td>
                    <td style="text-align: right; font-size: 12px; white-space: nowrap; padding-right: 4px;">
                        N&#176; <strong t-esc="o.name"/>
                    </td>
                </tr>
            </table>

            <!-- Bloc informations eleve (gauche) + recap net a payer (droite) -->
            <table style="width:100%; border-collapse: collapse; margin-bottom: 8px;">
                <tr>
                    <td style="width: 62%; vertical-align: top; font-size: 14px; line-height: 1.5;">
                        <div><strong>&#201;l&#232;ve :</strong> <t t-esc="o.student_id.name"/></div>
                        <div><strong>Classe :</strong> <t t-esc="o.classe_id.display_name"/></div>
                        <div><strong>Matricule :</strong> <t t-esc="o.student_id.gr_no or ''"/></div>
                        <!-- <div><strong>Annee scolaire :</strong> <t t-esc="o.academic_year_id.name"/></div> -->
                        <!-- <div>
                            <strong>Date paiement :</strong>
                            <t t-if="last_pay and last_pay.date">
                                <t t-esc="last_pay.date.strftime('%d/%m/%Y')"/>
                            </t>
                            <t t-else="">
                                <t t-esc="o.date.strftime('%d/%m/%Y') if o.date else ''"/>
                            </t>
                        </div> -->
                        <div t-if="mode_paiement"><strong>Mode de paiement :</strong> <t t-esc="mode_paiement"/></div>
                    </td>
                    <td style="width: 38%; vertical-align: top;">
                        <table style="width:100%; border-collapse: collapse; font-size: 12px;">
                            <tr>
                                <td style="border: 1px solid #999; padding: 4px 7px; background: #f0f0f0;">
                                    Net &#224; payer
                                </td>
                                <td style="border: 1px solid #999; padding: 4px 7px; text-align: right; font-weight: bold;">
                                    <t t-esc="'{:,.0f}'.format(total_tarif).replace(',', ' ')"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #999; padding: 4px 7px; background: #f0f0f0;">
                                    D&#233;j&#224; pay&#233;
                                </td>
                                <td style="border: 1px solid #999; padding: 4px 7px; text-align: right;">
                                    <t t-esc="'{:,.0f}'.format(total_paye).replace(',', ' ')"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #999; padding: 4px 7px; background: #f8d7da;">
                                    Reste &#224; payer
                                </td>
                                <td style="border: 1px solid #999; padding: 4px 7px; text-align: right; font-weight: bold; color: #842029;">
                                    <t t-esc="'{:,.0f}'.format(total_reste).replace(',', ' ')"/>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>

            <div style="font-size: 13px; margin-bottom: 3px;">
                <strong>Re&#231;u au montant de :</strong>
                <em><t t-esc="o._amount_to_words(montant_verse)"/></em>
            </div>
            <div style="font-size: 13px; margin-bottom: 7px;">
                <strong>LIBELLE :</strong> FRAIS EXIGIBLES
            </div>

            <div style="font-size: 12px; margin-bottom: 4px;">
                R&#233;capitulatif des versements sur frais exigibles en date du
                <strong><t t-esc="o.date.strftime('%d/%m/%Y') if o.date else ''"/></strong> :
            </div>

            <!-- Tableau recapitulatif des tranches -->
            <table style="width:100%; border-collapse: collapse; font-size: 12px; margin-bottom: 7px;">
                <thead>
                    <tr style="background: #714B67; color: #fff;">
                        <th style="border: 1px solid #999; padding: 4px 6px; text-align: left;">Tranche / Frais</th>
                        <th style="border: 1px solid #999; padding: 4px 6px;">Date limite</th>
                        <th style="border: 1px solid #999; padding: 4px 6px; text-align: right;">Tarif</th>
                        <th style="border: 1px solid #999; padding: 4px 6px; text-align: right;">D&#233;j&#224; pay&#233;</th>
                        <th style="border: 1px solid #999; padding: 4px 6px; text-align: right;">Reste &#224; payer</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="recap_lines" t-as="line">
                        <tr>
                            <td style="border: 1px solid #999; padding: 4px 6px;"><t t-esc="line['label']"/></td>
                            <td style="border: 1px solid #999; padding: 4px 6px; text-align: center;">
                                <t t-esc="line['date'].strftime('%d/%m/%Y') if line['date'] else '-'"/>
                                <t t-if="line.get('moratorium')">
                                    <br/><span style="font-size: 10px; font-style: italic; color: #856404;">(moratoire)</span>
                                </t>
                            </td>
                            <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;">
                                <t t-esc="'{:,.0f}'.format(line['tarif']).replace(',', ' ')"/>
                            </td>
                            <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;">
                                <t t-esc="'{:,.0f}'.format(line['paye']).replace(',', ' ')"/>
                            </td>
                            <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;">
                                <t t-esc="'{:,.0f}'.format(line['reste']).replace(',', ' ')"/>
                            </td>
                        </tr>
                    </t>
                    <tr style="background: #f0f0f0; font-weight: bold;">
                        <td style="border: 1px solid #999; padding: 4px 6px;" colspan="2">TOTAUX</td>
                        <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;">
                            <t t-esc="'{:,.0f}'.format(total_tarif).replace(',', ' ')"/>
                        </td>
                        <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;">
                            <t t-esc="'{:,.0f}'.format(total_paye).replace(',', ' ')"/>
                        </td>
                        <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;">
                            <t t-esc="'{:,.0f}'.format(total_reste).replace(',', ' ')"/>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- Montant verse + enregistrement -->
            <table style="width:100%; border-collapse: collapse; margin-bottom: 9px;">
                <tr>
                    <td style="width: 50%; vertical-align: middle;">
                        <span style="font-size: 12px;">
                            Enregistr&#233; le
                            <t t-if="last_pay and last_pay.date">
                                <t t-esc="last_pay.date.strftime('%d/%m/%Y a %H:%M')"/>
                            </t>
                            par
                            <t t-esc="(last_pay.create_uid.name if last_pay and last_pay.create_uid else o.create_uid.name) or ''"/>
                        </span>
                    </td>
                    <td style="width: 50%; text-align: right; vertical-align: middle;">
                        <span style="font-size: 16px; font-weight: bold; background: #198754;
                                     color: #fff; padding: 4px 14px; border-radius: 3px;">
                            MONTANT VERSE :
                            <t t-esc="'{:,.0f}'.format(montant_verse).replace(',', ' ')"/> F
                        </span>
                    </td>
                </tr>
            </table>

            <!-- QR code + signature -->
            <table style="width:100%; border-collapse: collapse;">
                <tr>
                    <td style="width: 30%; vertical-align: bottom;">
                        <img t-if="qr_b64" t-att-src="'data:image/png;base64,%s' % qr_b64"
                             style="width: 74px; height: 74px;"/>
                    </td>
                    <td style="width: 40%;"></td>
                    <td style="width: 30%; text-align: center; vertical-align: bottom;">
                        <div style="border-top: 1px solid #333; padding-top: 4px; font-size: 12px;">
                            Signature Caissier(e)
                        </div>
                    </td>
                </tr>
            </table>

            <div style="text-align: center; font-size: 11px; font-style: italic;
                        color: #555; margin-top: 6px;">
                NB : Les frais de scolarite payes ne sont ni remboursables, ni transferables.
            </div>
        </div>
    </template>

    <!-- ══════════════════════════════════════════
         PAGE A4 : deux exemplaires (ecole / payeur)
    ══════════════════════════════════════════ -->
    <template id="report_student_fee_receipt_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="padding: 6px 14px; height: 100%; box-sizing: border-box;">
                    <div style="height: 48.5%; box-sizing: border-box;">
                        <t t-set="copy_label" t-value="'EXEMPLAIRE ECOLE'"/>
                        <t t-call="edutek_primaire_cm.report_student_fee_receipt_body"/>
                    </div>

                    <div style="text-align: center; margin: 4px 0; height: 3%;
                                border-top: 1px dashed #999; box-sizing: border-box;">
                        <span style="position: relative; top: -8px; background: #fff;
                                     padding: 0 8px; font-size: 9px; color: #888;">
                            &#9986; decouper ici
                        </span>
                    </div>

                    <div style="height: 48.5%; box-sizing: border-box;">
                        <t t-set="copy_label" t-value="'EXEMPLAIRE PAYEUR / ELEVE'"/>
                        <t t-call="edutek_primaire_cm.report_student_fee_receipt_body"/>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>
