<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_op_student_fee_list" model="ir.actions.report">
        <field name="name">Liste des frais</field>
        <field name="model">op.student.fee.list.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">edutek_primaire_cm.report_student_fee_list_document</field>
        <field name="report_file">edutek_primaire_cm.report_student_fee_list_document</field>
        <field name="print_report_name">'Liste des frais'</field>
        <field name="paperformat_id" ref="paperformat_school_document"/>
    </record>

    <template id="report_student_fee_list_document">
        <t t-call="web.html_container">
            <div class="page">
                <div style="text-align: right; font-size: 11px;">
                    <strong>Date / Heure :</strong> <span t-esc="now"/>
                </div>

                <t t-call="edutek_primaire_cm.report_school_letterhead"/>

                <t t-set="doc_title" t-value="'LISTE DES FRAIS'"/>
                <t t-call="edutek_primaire_cm.report_school_doc_title"/>

                <table style="width: 100%; border-collapse: collapse; font-size: 17px;">
                    <t t-set="table_headers" t-value="['N°', 'Date', 'Eleve', 'Classe', 'Type de frais', 'Periode', 'Montant', 'Reste', 'Statut']"/>
                    <t t-call="edutek_primaire_cm.report_school_table_head"/>
                    <tbody>
                        <t t-foreach="fees" t-as="fee" t-key="fee.id">
                            <tr t-att-style="'background: #f5f5f5;' if fee_index % 2 else ''">
                                <td style="border: 1px solid #999; padding: 4px 6px; text-align: center;" t-esc="fee_index + 1"/>
                                <td style="border: 1px solid #999; padding: 4px 6px;" t-esc="fee.date" t-options='{"widget": "date"}'/>
                                <td style="border: 1px solid #999; padding: 4px 6px;" t-esc="fee.student_id.name"/>
                                <td style="border: 1px solid #999; padding: 4px 6px;" t-esc="fee.classe_id.display_name or ''"/>
                                <td style="border: 1px solid #999; padding: 4px 6px;" t-esc="fee.fee_type_id.name"/>
                                <td style="border: 1px solid #999; padding: 4px 6px;" t-esc="fee.academic_term_id.display_name or ''"/>
                                <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;" t-esc="fee.amount" t-options='{"widget": "monetary", "display_currency": fee.currency_id}'/>
                                <td style="border: 1px solid #999; padding: 4px 6px; text-align: right;" t-esc="fee.amount_residual" t-options='{"widget": "monetary", "display_currency": fee.currency_id}'/>
                                <td style="border: 1px solid #999; padding: 4px 6px;" t-esc="payment_state_labels.get(fee.payment_state, fee.payment_state or '')"/>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <p t-if="not fees" style="text-align: center; color: #6c757d; margin-top: 16px;">
                    Aucun frais ne correspond a ces criteres.
                </p>
                <div t-else="" style="margin-top: 12px; font-size: 17px;">
                    <strong>Nombre de frais :</strong> <span t-esc="len(fees)"/>
                    <strong style="margin-left: 16px;">Montant total :</strong>
                    <span t-esc="sum(fees.mapped('amount'))"/>
                    <strong style="margin-left: 16px;">Reste total :</strong>
                    <span t-esc="sum(fees.mapped('amount_residual'))"/>
                </div>

                <t t-call="edutek_primaire_cm.report_school_footer"/>
            </div>
        </t>
    </template>

</odoo>
