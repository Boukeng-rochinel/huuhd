<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_edutek_configuration" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="path">res-config-settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module' : 'edutek_core'}</field>
    </record>
    <!-- Openeducat Menu -->
    <menuitem id="menu_op_school_root"
              name="EduTek"
              sequence="220"
              web_icon="edutek_core,static/description/sis.png"/>

    <menuitem id="menu_op_school_main"
              name="Élèves"
              parent="menu_op_school_root"
              sequence="10"
              action="act_open_op_student_view"
              groups="group_op_faculty"/>

    <menuitem id="menu_op_faculty_main"
              name="Enseignants"
              parent="menu_op_school_root"
              sequence="20"
              action="act_open_op_faculty_view"
              groups="edutek_core.group_op_faculty"/>

    <menuitem id="menu_op_general_main"
              name="Général"
              parent="menu_op_school_root"
              sequence="30"/>

    <!-- Configuration Menu -->
    <menuitem id="menu_op_school_config"
              name="Configuration"
              parent="menu_op_school_root"
              sequence="50"/>

    <menuitem id="menu_op_school_config_course"
              name="Filières"
              parent="menu_op_school_config"
              sequence="10"/>

    <menuitem id="menu_op_course_sub"
              name="Filières"
              parent="menu_op_school_config_course"
              sequence="10"
              action="act_open_op_course_view"
              groups="group_op_back_office_admin"/>

    <menuitem id="menu_op_batch_sub"
              name="Groupes"
              parent="menu_op_school_config_course"
              sequence="20"
              action="act_open_op_batch_view"
              groups="base.group_no_one"/>

    <menuitem id="menu_op_department_sub"
              name="Départements"
              parent="menu_op_school_config_course"
              sequence="20"
              action="act_open_op_department_view"
              groups="base.group_no_one"/>

    <menuitem id="menu_op_school_config_subject"
              name="Matières"
              parent="menu_op_school_config"
              sequence="20"/>

    <menuitem id="menu_op_subject_sub"
              name="Matières"
              sequence="10"
              parent="menu_op_school_config_subject"
              action="act_open_op_subject_view"
              groups="group_op_back_office_admin,edutek_core.group_op_faculty"/>

    <menuitem id="menu_op_school_config_general"
              name="Général"
              parent="menu_op_school_config"
              sequence="80"/>

    <menuitem id="menu_op_category_sub"
              name="Categories"
              parent="menu_op_school_config_general"
              sequence="40"
              action="act_open_op_category_view"
              groups="edutek_core.group_op_back_office_admin"/>

    <!-- Activity Root -->
    <menuitem id="menu_op_school_config_activity"
              name="Activity Management"
              parent="menu_op_school_config"
              sequence="40"
              groups="base.group_no_one"/>

    <!-- Report Root -->
    <menuitem id="menu_op_report_main"
              name="Reporting"
              parent="menu_op_school_root"
              sequence="40"/>

    <menuitem name="Settings"
              id="menu_edutek_config"
              action="action_edutek_configuration"
              parent="menu_op_school_config"
              groups="base.group_system"
              sequence="1"/>

    <menuitem id="menu_academic_year" name="Academic Year"
              sequence="1"
              parent="edutek_core.menu_op_school_config"
              action="act_op_academic_year_view"
              groups="edutek_core.group_op_back_office_admin"/>

    <menuitem id="menu_academic_term" name="Séquences / Périodes"
              sequence="2"
              parent="edutek_core.menu_op_school_config"
              action="act_op_academic_term_view"
              groups="edutek_core.group_op_back_office_admin"/>

    <menuitem id="menu_op_school_config_program"
              name="Niveaux / Programmes"
              parent="edutek_core.menu_op_school_config"
              sequence="9"/>

    <menuitem id="menu_op_program_sub"
              name="Programmes"
              parent="menu_op_school_config_program"
              sequence="10"
              action="act_open_op_program_view"
              groups="group_op_back_office_admin"/>

    <menuitem id="menu_op_program_level_sub"
              name="Niveaux"
              parent="menu_op_school_config_program"
              sequence="10"
              action="act_open_op_program_level_view"
              groups="group_op_back_office_admin"/>

</odoo>
