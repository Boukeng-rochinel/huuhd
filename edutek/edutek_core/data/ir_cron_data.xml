<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <!-- Desactive : ce cron envoyait quotidiennement les donnees de
             l'ecole (UUID base, nb utilisateurs, nom/email/telephone de la
             societe, liste des apps installees) au serveur de l'editeur
             d'origine (srv.openeducat.org) via update_notification_edutek()
             dans models/update.py. Sans relation contractuelle avec cet
             editeur, ce transfert de donnees n'a plus lieu d'etre. -->
        <record id="ir_cron_module_update_notification_edutek" model="ir.cron">
            <field name="name">Publisher: Update Notification EduTek</field>
            <field name="model_id" ref="model_publisher_warranty_contract"/>
            <field name="state">code</field>
            <field name="code">model.update_notification_edutek(None)</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">1000</field>
            <field name="active" eval="False"/>
        </record>

        <record id="base.ir_cron_act" model="ir.actions.act_window">
            <field name="domain" eval="[('id', 'not in', [ref('mail.ir_cron_module_update_notification'),ref('edutek_core.ir_cron_module_update_notification_edutek'),])]"/>
        </record>
</odoo>
